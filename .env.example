# =============================================================================
# SEO-Tools environment variables
# Copy this file to .env and fill in the values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (separate project from any client-facing site DB)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# OpenRouter (unified LLM gateway -- chat + embeddings through one API)
# See docs/adr/0005-openrouter-unified-gateway.md
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional but recommended: OpenRouter uses these for per-app analytics + abuse-prevention
OPENROUTER_HTTP_REFERER=https://webleymedia.com
OPENROUTER_APP_TITLE=SEO-Tools

# -----------------------------------------------------------------------------
# Active model selection (dynamic -- swap these to change models with NO code changes).
# Slugs are OpenRouter model IDs; browse https://openrouter.ai/models for options.
#
# WARNING: changing DEFAULT_EMBEDDING_MODEL or DEFAULT_EMBEDDING_DIMS requires
# re-embedding all prior data (vectors are in incompatible latent spaces across
# models). Chat-model swaps only change llm_prompt_hash and cohort audit results.
# See docs/adr/0005-openrouter-unified-gateway.md for the swap runbook.
# -----------------------------------------------------------------------------
DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small
DEFAULT_EMBEDDING_DIMS=768
DEFAULT_LLM_MODEL=google/gemini-2.0-flash-001
DEFAULT_CROSS_VALIDATION_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# SerpAPI
# -----------------------------------------------------------------------------
SERPAPI_KEY=

# -----------------------------------------------------------------------------
# HITL channels (configure one or both)
# -----------------------------------------------------------------------------

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL_ID=
SLACK_HITL_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# -----------------------------------------------------------------------------
# Python clustering worker (deployed to Cloud Run / Railway / Fly.io)
# -----------------------------------------------------------------------------
PYTHON_WORKER_URL=https://YOUR_WORKER.run.app
PYTHON_WORKER_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# n8n instance
# -----------------------------------------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# -----------------------------------------------------------------------------
# Google integrations
# -----------------------------------------------------------------------------
# OAuth client for Google Sheets sync (intern view)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
SHEETS_INTERN_VIEW_SPREADSHEET_ID=

# -----------------------------------------------------------------------------
# WordPress (headless) integration
# Used by WF-00 to inventory blog posts for cannibalization checks.
# -----------------------------------------------------------------------------
WPGRAPHQL_ENDPOINT=https://YOUR_WP/graphql
WPGRAPHQL_AUTH_HEADER=

# -----------------------------------------------------------------------------
# Cost guardrail defaults (overridable per-client via clients.config)
# -----------------------------------------------------------------------------
DEFAULT_MONTHLY_API_BUDGET_USD=50
DEFAULT_EXPECTED_RUNS_PER_MONTH=4
DEFAULT_PER_RUN_COST_CEILING_PCT=150

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development

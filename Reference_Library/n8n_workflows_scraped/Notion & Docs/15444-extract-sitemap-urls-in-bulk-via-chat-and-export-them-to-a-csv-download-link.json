        {
            "id": "39bfacbc-a363-41ed-b531-a333f4e9c9b6",
            "name": "Extract Download URL",
            "type": "n8n-nodes-base.code",
            "position": [
                5328,
                528
            ],
            "parameters": {
                "jsCode": "const url = $json.files?.[0]?.url;\nreturn [\n  {\n    json: {\n      message: `<${url}>`\n    }\n  }\n];"
            },

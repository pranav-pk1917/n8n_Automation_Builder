                "source": "={{ $json.source }}",
                "engines": [
                    "ai-overview",
                    "chatgpt",
                    "perplexity",
                    "gemini"
                ],
                "resource": "aiSearch",
                "operation": "getLeaderboard",
                "competitors": {
                    "competitorValues": [

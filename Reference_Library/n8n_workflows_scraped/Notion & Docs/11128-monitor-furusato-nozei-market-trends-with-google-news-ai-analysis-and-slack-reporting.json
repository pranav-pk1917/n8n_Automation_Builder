            "parameters": {
                "color": 7,
                "width": 182,
                "height": 256,
                "content": "**Regional Settings:**\n   - The workflow is pre-set for Japan (`jp` / `ja`). If you need to change this, check the `Workflow Configuration` and `Google Trends API` nodes.\n"
            },
            "typeVersion": 1
        },
        {

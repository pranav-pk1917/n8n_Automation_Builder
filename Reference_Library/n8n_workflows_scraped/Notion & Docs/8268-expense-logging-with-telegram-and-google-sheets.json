        {
            "id": "043a639f-0605-4e05-8ea2-fc2567fc7670",
            "name": "Telegram - Get Expense Command",
            "type": "n8n-nodes-base.telegramTrigger",
            "position": [
                464,
                592
            ],
            "webhookId": "b794fd0e-d6fa-442c-b916-0eb73f65f448",

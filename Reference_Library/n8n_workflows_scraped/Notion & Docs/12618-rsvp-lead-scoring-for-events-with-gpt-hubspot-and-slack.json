                    "conditions": [
                        {
                            "id": "id-1",
                            "operator": {
                                "type": "string",
                                "operation": "notEmpty"
                            },
                            "leftValue": "={{ $('Set Workflow Variables').item.json.email }}"
                        },
                        {
                            "id": "id-2",
                            "operator": {
                                "type": "string",
                                "operation": "regex"
                            },
                            "leftValue": "={{ $('Set Workflow Variables').item.json.email }}",

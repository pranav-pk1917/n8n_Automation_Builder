                "table": {
                    "__rl": true,
                    "mode": "name",
                    "value": "Reviews"
                },
                "options": {},
                "operation": "search",
                "filterByFormula": "AND({Rating}=5, {Posted}=FALSE())"
            },
            "typeVersion": 2.1
        },
        {
            "id": "8566775a-0cd9-4296-8778-33ce8218e49a",
            "name": "IF \u2014 Has Valid Review?",
            "type": "n8n-nodes-base.if",
            "position": [
                1008,
                400
            ],
            "parameters": {
                "options": {},
                "conditions": {
                    "options": {
                        "leftValue": "",
                        "caseSensitive": true,
                        "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "has-review",
                            "operator": {
                                "type": "string",
                                "operation": "notEmpty"
                            },
                            "leftValue": "={{ $json.id }}",
                            "rightValue": ""
                        }
                    ]
                }
            },
            "typeVersion": 2.2

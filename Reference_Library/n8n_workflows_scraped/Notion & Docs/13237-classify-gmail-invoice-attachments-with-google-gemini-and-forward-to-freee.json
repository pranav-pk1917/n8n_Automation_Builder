            "type": "n8n-nodes-base.stickyNote",
            "position": [
                -1264,
                1824
            ],
            "parameters": {
                "color": 7,
                "width": 480,
                "height": 300,
                "content": "### Forward to freee\nRe-fetches the original attachment and forwards the email to freee's File Box receiving address."
            },
            "typeVersion": 1
        },

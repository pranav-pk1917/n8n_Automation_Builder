        {
            "id": "fetch-sitemap",
            "name": "Fetch Sitemap XML",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                432,
                240
            ],
            "parameters": {
                "url": "={{ $json.sitemapUrl }}",
                "options": {

            ],
            "parameters": {
                "filters": {
                    "conditions": [
                        {
                            "keyName": "vendor_name",
                            "keyValue": "={{ $json.vendor_name }}",
                            "condition": "eq"
                        }
                    ]
                },
                "tableId": "vendors",
                "operation": "getAll",
                "returnAll": true

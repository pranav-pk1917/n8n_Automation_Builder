            "parameters": {
                "url": "https://app.pennylane.com/api/external/v2/customer_invoices",
                "method": "POST",
                "options": {},
                "jsonBody": "={{ JSON.stringify($json) }}",
                "sendBody": true,
                "specifyBody": "json",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth"

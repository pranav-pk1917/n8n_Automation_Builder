            "parameters": {
                "jsCode": "const content = $json.message?.content || '';\nlet parsed;\ntry { const m = content.match(/\\{[\\s\\S]*\\}/); parsed = m ? JSON.parse(m[0]) : { ranking: [] }; } catch(e) { parsed = { ranking: [] }; }\nreturn [{ json: { newRanking: parsed.ranking || [] } }];"

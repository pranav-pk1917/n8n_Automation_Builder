                    "options": {
                        "leftValue": "",
                        "caseSensitive": true,
                        "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "cond-1",
                            "operator": {
                                "type": "boolean",
                                "operation": "true"
                            },
                            "leftValue": "={{ $json.isQualified }}",
                            "rightValue": true
                        }
                    ]
                }
            },
            "typeVersion": 2
        },
        {
            "id": "a1000001-1000-0000-0000-000000000008",
            "name": "Alert sales team about hot lead",
            "type": "n8n-nodes-base.slack",

            "parameters": {
                "color": 4,
                "width": 368,
                "height": 192,
                "content": "## Process in Batches\n\nEnsures videos are handled one by one.\nPrevents large uploads from overloading memory and makes error recovery easier."
            },
            "typeVersion": 1
        },
        {
            "id": "e1ea7552-4668-4d16-bd9c-d47464bdd3d9",

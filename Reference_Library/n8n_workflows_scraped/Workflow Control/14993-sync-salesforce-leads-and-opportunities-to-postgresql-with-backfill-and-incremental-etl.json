            "id": "499aaf25-5440-4249-a669-3e6d14ba2e2a",
            "name": "Set Historical Date Range",
            "type": "n8n-nodes-base.set",
            "position": [
                -896,
                192
            ],
            "parameters": {
                "mode": "raw",
                "options": {},
                "jsonOutput": "{\n  \"start_date\": \"2025-12-07\",\n  \"end_date\": \"2026-04-11\"\n}"

            "type": "n8n-nodes-base.googleSheetsTrigger",
            "position": [
                -1696,
                160
            ],
            "parameters": {
                "event": "rowUpdate",
                "options": {},
                "pollTimes": {
                    "item": [
                        {
                            "mode": "everyMinute"
                        }
                    ]
                },
                "sheetName": {
                    "__rl": true,
                    "mode": "list",
                    "value": "YOUR_RESOURCE_ID_HERE"
                },
                "documentId": {

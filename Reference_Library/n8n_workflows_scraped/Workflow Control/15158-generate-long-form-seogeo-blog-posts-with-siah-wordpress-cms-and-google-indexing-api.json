                "assignments": {
                    "assignments": [
                        {
                            "id": "6974c1dd-ad46-4766-8535-620558401c8b",
                            "name": "website",
                            "type": "string",
                            "value": "https://YOUR-WEBSITE-URL.com"
                        }
                    ]
                }
            },
            "typeVersion": 3.4
        },

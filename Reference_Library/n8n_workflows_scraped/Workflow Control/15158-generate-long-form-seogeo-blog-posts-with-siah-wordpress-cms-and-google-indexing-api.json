        {
            "id": "d88eae4d-b6cf-4ecd-b5bc-62cc14cabf87",
            "name": "Generate Full SEO blog",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                1264,
                -784
            ],
            "parameters": {
                "url": "=https://seosiah.com/api/v1/public/generate/from-suggestion",
                "method": "POST",
                "options": {},
                "sendBody": true,
                "authentication": "genericCredentialType",
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "suggestionId",
                            "value": "={{ $json.id }}"
                        },
                        {
                            "name": "contentLength",
                            "value": "medium"

        {
            "id": "0c8ee32c-b38b-4e91-b780-f3e30be09ac5",
            "name": "Read products.json",
            "type": "n8n-nodes-base.readWriteFile",
            "position": [
                3280,
                1248
            ],
            "parameters": {

            "type": "n8n-nodes-base.stickyNote",
            "position": [
                -96,
                -144
            ],
            "parameters": {
                "color": 7,
                "width": 384,
                "height": 288,
                "content": "## Create a room\nCreate a multiplayer room and initialize it with a Storage value. In a real app, this'll already be created."

                            "value": "={{ $json.subject || $json.body?.subject }}"
                        },
                        {
                            "name": "body",
                            "type": "string",
                            "value": "={{ $json.text || $json.body?.text || $json.body }}"
                        },
                        {
                            "name": "messageId",
                            "type": "string",
                            "value": "={{ $json.messageId || Date.now().toString() }}"
                        }
                    ]
                }
            },
            "typeVersion": 3.4
        },

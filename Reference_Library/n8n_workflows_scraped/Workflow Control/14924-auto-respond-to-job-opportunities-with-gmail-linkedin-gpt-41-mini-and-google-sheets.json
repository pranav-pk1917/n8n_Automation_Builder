            ],
            "parameters": {
                "options": {},
                "assignments": {
                    "assignments": [
                        {
                            "name": "sender",
                            "type": "string",
                            "value": "={{ $json.from || $json.body?.from }}"
                        },
                        {
                            "name": "subject",

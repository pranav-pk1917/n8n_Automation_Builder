        {
            "id": "939ea07b-1f6a-4d31-928d-2a9cfa70e0ee",
            "name": "Read sheet closed",
            "type": "n8n-nodes-base.googleSheets",
            "position": [
                848,
                336
            ],
            "parameters": {
                "options": {},
                "sheetName": {
                    "__rl": true,
                    "mode": "name",
                    "value": "closed"
                },
                "documentId": {
                    "__rl": true,

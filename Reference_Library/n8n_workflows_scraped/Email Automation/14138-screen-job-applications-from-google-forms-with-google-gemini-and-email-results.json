                "method": "PUT",
                "options": {},
                "jsonBody": "={{ JSON.stringify($json._requestBody) }}",
                "sendBody": true,
                "specifyBody": "json",
                "authentication": "predefinedCredentialType",
                "nodeCredentialType": "googleSheetsOAuth2Api"
            },
            "typeVersion": 4.2
        },

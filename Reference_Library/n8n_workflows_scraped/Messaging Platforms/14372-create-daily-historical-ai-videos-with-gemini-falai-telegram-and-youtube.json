            "webhookId": "e89251c2-970d-44c5-8dbd-f06815e74f35",
            "parameters": {
                "chatId": "123456789",
                "message": "Please approve or reject this video:",
                "options": {},
                "operation": "sendAndWait",
                "approvalOptions": {
                    "values": {
                        "approvalType": "double"
                    }

            "name": "Prepare Approval Message",
            "type": "n8n-nodes-base.code",
            "position": [
                12048,
                15744
            ],
            "parameters": {
                "jsCode": "// Prepare message with video info and approval buttons\nconst info = $node[\"Extract Video Metadata\"].json;\nconst maxRetries = 3;\n\nconst retryInfo = info.attemptNumber > 1 \n ? `\\n\ud83d\udd04 *Attempt ${info.attemptNumber}/${maxRetries}* (previous declined)`\n : '';\n\nconst caption = `\ud83c\udfac *Historical Video*${retryInfo}\n\n\ud83d\udcc5 *Event:* ${info.eventDescription.substring(0, 150)}\n\ud83d\uddd3\ufe0f *Year:* ${info.eventYear}\n\n\ud83d\udcdd *Script:*\n${info.script.substring(0, 200)}${info.script.length > 200 ? '...' : ''}\n\n\u2753 *Upload to YouTube?*\n/yes - Upload this video\n/no - Try another event\n/stop - Stop workflow`;\n\nreturn { \n caption: caption,\n videoUrl: info.videoUrl,\n eventYear: info.eventYear,\n eventDescription: info.eventDescription,\n script: info.script,\n attemptNumber: info.attemptNumber\n};"
            },
            "typeVersion": 2
        },
        {
            "id": "4727dcd0-5412-4aaa-b1fb-98f7e32a2e3d",
            "name": "Wait for User Approval",

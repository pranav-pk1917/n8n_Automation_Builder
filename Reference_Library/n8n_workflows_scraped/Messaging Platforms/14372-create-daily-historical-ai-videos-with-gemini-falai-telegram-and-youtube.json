            "type": "n8n-nodes-base.code",
            "position": [
                13616,
                15728
            ],
            "parameters": {
                "jsCode": "// Send final confirmation after successful YouTube upload\nconst uploadResult = $input.first().json;\nconst videoInfo = $node[\"Extract Video Metadata\"].json;\n\nconst message = `\u2705 *Video uploaded to YouTube!*\n\n\ud83d\udcf9 *Watch:* https://www.youtube.com/watch?v=${uploadResult.id}\n\ud83d\udcc5 *Event:* ${videoInfo.eventDescription.substring(0, 100)}\n\ud83d\uddd3\ufe0f *Year:* ${videoInfo.eventYear}`;\n\nreturn { message: message };"
            },

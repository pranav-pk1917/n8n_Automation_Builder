            "id": "ad0e705c-dfd7-4861-adce-2e11c8304e51",
            "name": "Telegram Trigger",
            "type": "n8n-nodes-base.telegramTrigger",
            "position": [
                1440,
                208
            ],
            "webhookId": "telegram-ecom-bot",
            "parameters": {
                "updates": [
                    "message",
                    "callback_query"
                ],
                "additionalFields": {}
            },
            "typeVersion": 1.2

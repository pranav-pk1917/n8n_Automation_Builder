                            "field": "minutes",
                            "minutesInterval": 10
                        }
                    ]
                }
            },
            "typeVersion": 1.2
        },
        {
            "id": "02635c58-b2d9-4a39-b877-4150d1955eec",
            "name": "Shopify \u2014 Fetch Recent Products (API)",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                1568,
                1456
            ],
            "parameters": {
                "url": "=https://{{ $vars.SHOPIFY_STORE_DOMAIN }}/admin/api/2024-01/products.json",
                "options": {
                    "timeout": 15000
                },
                "sendQuery": true,
                "sendHeaders": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "status",
                            "value": "active"
                        },
                        {
                            "name": "published_status",
                            "value": "published"
                        },
                        {
                            "name": "limit",
                            "value": "10"
                        },
                        {
                            "name": "published_at_min",
                            "value": "={{ new Date(Date.now() - 15 * 60 * 1000).toISOString() }}"
                        },
                        {
                            "name": "fields",
                            "value": "id,title,body_html,vendor,handle,images,variants,tags,product_type"
                        }
                    ]
                },
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "X-Shopify-Access-Token",
                            "value": "={{ $vars.SHOPIFY_ACCESS_TOKEN }}"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                }
            },
            "typeVersion": 4.2
        },
        {
            "id": "7157a463-daa9-412a-961f-3f9937bd59d6",
            "name": "Code \u2014 Extract & Validate Products",
            "type": "n8n-nodes-base.code",
            "position": [
                1760,
                1456
            ],
            "parameters": {
                "jsCode": "// Extract products array from Shopify response\nconst products = $input.first().json?.products || [];\n\nif (!products.length) {\n  return [];\n}\n\n// Filter: must have title + at least one image\nconst valid = products.filter(p =>\n  p.title &&\n  p.images?.length > 0 &&\n  parseFloat(p.variants?.[0]?.price || '0') >= 1\n);\n\nreturn valid.map(p => ({\n  json: {\n    productId: String(p.id),\n    title: p.title,\n    description: (p.body_html || '')\n      .replace(/<[^>]+>/g, '')\n      .replace(/\\s+/g, ' ')\n      .trim()\n      .substring(0, 450),\n    price: `$${parseFloat(p.variants?.[0]?.price || '0').toFixed(2)}`,\n    rawPrice: parseFloat(p.variants?.[0]?.price || '0'),\n    productUrl: `https://${p.vendor?.toLowerCase().replace(/\\s+/g,'-')}.myshopify.com/products/${p.handle}`,\n    imageUrl: p.images[0]?.src || '',\n    allImages: p.images.slice(0, 3).map(i => i.src),\n    tags: (typeof p.tags === 'string' ? p.tags.split(',') : p.tags || []).map(t => t.trim()).filter(Boolean).slice(0, 6),\n    vendor: p.vendor || 'Store',\n    productType: p.product_type || ''\n  }\n}));"
            },
            "typeVersion": 2
        },

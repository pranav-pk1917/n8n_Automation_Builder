            ],
            "parameters": {
                "color": 7,
                "width": 656,
                "height": 648,
                "content": "## STEP4: Content Retrieval & Preparation\nPrepare article links, fetch each article HTML, and extract and clean the main text content for further processing"
            },
            "typeVersion": 1
        },
        {

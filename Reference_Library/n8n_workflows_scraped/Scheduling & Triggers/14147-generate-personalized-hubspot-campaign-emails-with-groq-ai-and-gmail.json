            "parameters": {
                "jsCode": "let text =$input.first().json.output ;\n\n// convert escaped newline characters to real HTML line breaks\ntext = text.replace(/\\\\n/g, \"<br><br>\");\n\nreturn [\n  {\n    json: {\n      campaign: text\n    }\n  }\n];"

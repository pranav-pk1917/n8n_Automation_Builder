            "parameters": {
                "color": 7,
                "width": 380,
                "height": 280,
                "content": "## Scrape competitor page\n\nFirecrawl fetches the page and returns clean markdown. Handles JavaScript-rendered SPAs, anti-bot protection, and removes navigation and ads automatically."
            },
            "typeVersion": 1
        },

                            "field": "cronExpression",
                            "expression": "0 8 * * 1"
                        }
                    ]
                }
            },
            "typeVersion": 1.2
        },
        {
            "id": "760f4f3d-1c7d-489c-8e65-d59d1dfe22f5",

        {
            "id": "664a732f-0f77-4d3e-816c-1547a5131208",
            "name": "1. Schedule \u2014 Every Monday 8AM",
            "type": "n8n-nodes-base.scheduleTrigger",
            "position": [
                2560,
                1152
            ],
            "parameters": {
                "rule": {
                    "interval": [

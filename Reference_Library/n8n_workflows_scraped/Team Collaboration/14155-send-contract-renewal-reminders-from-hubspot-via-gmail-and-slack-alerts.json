            "id": "d3c6c77f-de19-4e21-bc1d-3ac405288f64",
            "name": "Get all deals",
            "type": "n8n-nodes-base.hubspot",
            "position": [
                20576,
                5712
            ],
            "parameters": {
                "filters": {
                    "properties": [
                        "contract_expiry_date",
                        "dealname"

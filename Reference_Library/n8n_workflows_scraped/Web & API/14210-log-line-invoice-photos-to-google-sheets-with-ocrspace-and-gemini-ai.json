                "jsCode": "const binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst base64 = binaryData.toString('base64');\n\nreturn [{\n  json: {\n    data: base64,\n    mimeType: 'image/jpeg'\n  }\n}];"

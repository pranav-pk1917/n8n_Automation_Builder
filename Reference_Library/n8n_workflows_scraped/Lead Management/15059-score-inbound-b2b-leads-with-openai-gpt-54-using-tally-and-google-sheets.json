        {
            "id": "371b9931-4231-42fc-818b-947d090a07bc",
            "name": "Strip HTML to Plain Text",
            "type": "n8n-nodes-base.code",
            "position": [
                6688,
                2208
            ],
            "parameters": {
                "jsCode": "const lead = $('Map Lead Fields').first().json;\nconst html = $input.first().json.data || $input.first().json.body || '';\n\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<nav[\\s\\S]*?<\\/nav>/gi, ' ')\n  .replace(/<footer[\\s\\S]*?<\\/footer>/gi, ' ')\n  .replace(/<head[\\s\\S]*?<\\/head>/gi, ' ')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '\"').replace(/&nbsp;/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst truncated = text.length > 6000 ? text.substring(0, 6000) + '...[truncated]' : text;\n\nreturn [{ json: { ...lead, homepage_text: truncated } }];"
            },
            "typeVersion": 2
        },

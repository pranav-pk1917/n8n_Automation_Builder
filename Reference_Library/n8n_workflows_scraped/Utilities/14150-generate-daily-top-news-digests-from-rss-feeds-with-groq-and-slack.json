            ],
            "parameters": {
                "jsCode": "const data = $input.first().json;\n\nconst result = Object.entries(data).map(([key, value]) => {\n  return {\n    json: {\n      Rss_Feed: value\n    }\n  };\n});\n\nreturn result;"

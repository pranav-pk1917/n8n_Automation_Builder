            "parameters": {
                "url": "https://api.stripe.com/v1/coupons",
                "method": "POST",
                "options": {},
                "sendBody": true,
                "authentication": "predefinedCredentialType",
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "percent_off",
                            "value": "={{ $json.mrr > 10000 ? 20 : 10 }}"
                        },
                        {
                            "name": "duration",
                            "value": "repeating"
                        },
                        {
                            "name": "duration_in_months",
                            "value": "3"
                        },
                        {
                            "name": "id",
                            "value": "={{ 'RETAIN_' + $json.customer_id + '_' + Date.now() }}"

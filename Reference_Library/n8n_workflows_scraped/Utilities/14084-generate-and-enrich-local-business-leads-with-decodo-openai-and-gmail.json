            "id": "decodo-maps-1",
            "name": "Decodo: Scrape Google Maps",
            "type": "@decodo/n8n-nodes-decodo.decodo",
            "position": [
                4320,
                2944
            ],
            "parameters": {
                "geo": "={{ $json.geo }}",

        {
            "id": "537d4372-24cd-4a3d-a5eb-b682844df5f8",
            "name": "Build Payload note",
            "type": "n8n-nodes-base.stickyNote",
            "position": [
                18000,
                5984
            ],
            "parameters": {
                "width": 250,
                "height": 60,
                "content": "Validates required fields and builds a clean structured payload"
            },
            "typeVersion": 1

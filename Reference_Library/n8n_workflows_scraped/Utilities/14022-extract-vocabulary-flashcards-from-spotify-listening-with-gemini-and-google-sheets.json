            ],
            "parameters": {
                "color": 3,
                "width": 224,
                "height": 128,
                "content": "\u26a0\ufe0f Set your Google Cloud app to \"In Production\" \u2014 in \"Testing\" mode, tokens expire after 7 days and break the weekly automation."
            },
            "typeVersion": 1
        },
        {
            "id": "7a525920-6616-4cca-8207-165635336ae0",

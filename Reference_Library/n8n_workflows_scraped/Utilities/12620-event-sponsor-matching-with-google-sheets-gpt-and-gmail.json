                    "assignments": [
                        {
                            "id": "id-1",
                            "name": "aiResponse",
                            "type": "object",
                            "value": "={{ JSON.parse($json.message.content) }}"
                        },
                        {
                            "id": "id-2",
                            "name": "topPackage",
                            "type": "string",
                            "value": "={{ JSON.parse($json.message.content).recommendations[0].packageName }}"
                        },
                        {
                            "id": "id-3",
                            "name": "topScore",
                            "type": "number",
                            "value": "={{ JSON.parse($json.message.content).recommendations[0].score }}"
                        }
                    ]
                },
                "includeOtherFields": true
            },
            "typeVersion": 3.4
        },

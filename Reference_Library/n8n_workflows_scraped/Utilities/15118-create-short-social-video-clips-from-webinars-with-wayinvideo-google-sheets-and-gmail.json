            "parameters": {
                "url": "=https://wayinvideo-api.wayin.ai/api/v2/clips/results/{{ $json.projectId }}",
                "options": {},
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $json.wayinVideoApiKey }}"
                        },

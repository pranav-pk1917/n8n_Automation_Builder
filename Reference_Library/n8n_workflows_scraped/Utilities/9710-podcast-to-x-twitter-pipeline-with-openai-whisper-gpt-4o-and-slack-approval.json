        {
            "id": "a22f2cbd-ae46-4936-86cb-81cf2555b1bf",
            "name": "[Step 11] LLM \u2014 Summarize as News Bullets",
            "type": "@n8n/n8n-nodes-langchain.openAi",
            "position": [
                2480,

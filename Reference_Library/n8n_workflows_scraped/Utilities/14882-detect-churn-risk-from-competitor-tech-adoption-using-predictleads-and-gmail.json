                            },
                            "leftValue": "={{$json[\"competitorDetected\"]}}",
                            "rightValue": false
                        }
                    ]
                }
            },
            "typeVersion": 2.3
        },
        {
            "id": "480e1730-c5a7-437c-9a86-22e5561f7425",
            "name": "Notify Team (No Competitor - Safe Account)",

        {
            "id": "be44bc84-913f-46ad-baf7-b8691d3a746d",
            "name": "Inject duty name",
            "type": "n8n-nodes-base.code",
            "position": [
                1184,
                384
            ],
            "parameters": {
                "jsCode": "const calendarEvents = $input.all();\nconst classification = $('Parse AI Response').first().json;\n\nlet onCallUser = 'unknown';\n\nfor (const event of calendarEvents) {\n  const summary = event.json.summary || '';\n  const match = summary.match(/@(\\S+)/);\n  if (match) {\n    onCallUser = match[1]; // \"sergey\"\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...classification,\n    on_call_user: onCallUser\n  }\n}];"
            },
            "typeVersion": 2
        },

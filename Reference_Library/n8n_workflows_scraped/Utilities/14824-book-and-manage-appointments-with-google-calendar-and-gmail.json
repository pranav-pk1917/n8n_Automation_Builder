            ],
            "webhookId": "eebd3b07-d80b-47dc-a9ed-b01a9bd3ef40",
            "parameters": {
                "sendTo": "={{ $json.email }}",
                "message": "=<p>Dear {{ $json.name }},</p>\n\n<p>Your appointment has been confirmed!</p>\n\n<p><strong>Appointment Details:</strong></p>\n<ul>\n  <li><strong>Date & Time:</strong> {{ new Date($json.requestedDateTime).toLocaleString() }}</li>\n  <li><strong>Duration:</strong> {{ $json.duration || '30' }} minutes</li>\n</ul>\n\n<p>A calendar invitation has been sent to your email. You can also view the event in your calendar using the link below:</p>\n\n<p><a href=\"{{ $('Create Calendar Event').item.json.htmlLink }}\">View Calendar Event</a></p>\n\n<p>If you need to reschedule or cancel, please contact us as soon as possible.</p>\n\n<p>We look forward to seeing you!</p>\n\n<p>Best regards,<br>Your Team</p>",

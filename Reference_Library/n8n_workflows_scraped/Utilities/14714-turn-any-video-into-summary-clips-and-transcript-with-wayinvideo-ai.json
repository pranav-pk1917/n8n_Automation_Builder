                            "name": "fullTranscript",
                            "type": "string",
                            "value": "={{ $('11. WayinVideo \u2014 Poll Transcription Results').item.json.data.transcript.map(t => '[' + t.speaker + ' @ ' + Math.round(t.start/1000) + 's] ' + t.text).join('\\n') }}"
                        },

                464,
                -144
            ],
            "parameters": {
                "color": 5,
                "width": 208,
                "height": 212,
                "content": "## \ud83d\udccb Step 1 \u2014 User Input\nForm collects video URL, department topic, and desired question count."
            },
            "typeVersion": 1
        },

        {
            "id": "c4acc737-3324-4429-9eb3-d6fd32cb8207",
            "name": "Classify Issue",
            "type": "@n8n/n8n-nodes-langchain.openAi",
            "onError": "continueRegularOutput",
            "maxTries": 2,
            "position": [
                2064,

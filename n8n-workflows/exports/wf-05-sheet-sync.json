      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "value": "={{ $json.sheets_id }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Cost",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": {}
        },
        "options": {}
      },
      "id": "write-cost-tab",
      "name": "Write_Cost_Tab",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1320, 100],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred-id",
          "name": "GoogleSheets_SEOTools"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://slack.com/api/chat.postMessage",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={{ JSON.stringify({ channel: 'C0B43A7QG5P', text: '📊 Sheet sync complete: ' + $json.client_name, blocks: [{ type: 'section', text: { type: 'mrkdwn', text: '*Nightly sheet sync complete for:* ' + $json.client_name + '\\n*Clusters synced:* ' + $json.cluster_count + '\\n*Sheets ID:* ' + ($json.sheets_id || 'Not configured — create a sheet and add sheets_view_id to clients.config') } }] }) }}"
      },
      "id": "send-sync-notification",
      "name": "Send_Sync_Notification",

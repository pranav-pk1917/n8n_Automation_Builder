      {
        "parameters": {
          "url": "={{ $env.SUPABASE_URL }}/rest/v1/clusters?client_id=eq.{{ $json.client_id }}&priority_score=is.null&select=id,canonical_head_term,theme_label,suggested_service_pillar,pillar_assignment_confidence,content_theme,keyword_count,cannibalization_risk_page_id",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "sendHeaders": true,

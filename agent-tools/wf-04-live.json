          "id": "2e11fd70-3965-4073-a2f9-bc64ad09cbe5",
          "name": "Fetch_Unscored_Clusters",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.2,
          "position": [
            1216,
            512
          ]
        },
        {
          "parameters": {
            "jsCode": "// Check cost ceiling before starting expensive SerpAPI calls\nconst client = ($('Fetch_Client_Config').first().json || [])[0];\nconst clusters = $input.first().json || [];\nconst ctx = $('Validate_Score_Payload').first().json;\n\nconst budget = client?.config?.monthly_api_budget_usd || 50;\nconst runsPerMonth = client?.config?.expected_runs_per_month || 4;\nconst ceilingPct = client?.config?.per_run_cost_ceiling_pct || 150;\nconst perRunCeiling = (budget / runsPerMonth) * (ceilingPct / 100);\n\n// SerpAPI costs ~$0.01 per search, we do 3 per cluster, cap at 100 clusters\nconst maxClusters = Math.min(100, clusters.length);\nconst estimatedCost = maxClusters * 3 * 0.01;\n\nif (estimatedCost > perRunCeiling) {\n  throw new Error(`Cost ceiling would be exceeded: estimated $${estimatedCost.toFixed(2)} > ceiling $${perRunCeiling.toFixed(2)}. Reduce cluster count or increase budget.`);\n}\n\nreturn clusters.slice(0, maxClusters).map(cluster => ({\n  json: {\n    ...ctx,\n    client_config: client?.config || {},\n    cluster_id: cluster.id,\n    head_term: cluster.canonical_head_term,\n    theme_label: cluster.theme_label,\n    suggested_service_pillar: cluster.suggested_service_pillar,\n    pillar_assignment_confidence: cluster.pillar_assignment_confidence || 0,\n    content_theme: cluster.content_theme,\n    keyword_count: cluster.keyword_count || 0,\n    cannibalization_risk_page_id: cluster.cannibalization_risk_page_id\n  }\n}));"
          },
          "id": "518b3d61-58d4-47c8-a7c5-46ad8b8e607f",
          "name": "Check_Cost_Ceiling",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            1424,
            512
          ]
        },
        {
          "parameters": {
            "url": "=https://serpapi.com/search.json?q={{ encodeURIComponent($json.head_term) }}&num=3&api_key={{ $env.SERPAPI_KEY }}",
            "options": {}
          },
          "id": "38098eb0-18fa-4104-9fe4-9f3617c6f9ea",
          "name": "SerpAPI_Search",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.2,
          "position": [
            1648,
            512
          ]
        },
        {
          "parameters": {
            "jsCode": "// Parse SERP results and build LLM ICP scoring request\nconst ctx = $('Check_Cost_Ceiling').item.json;\nconst serpData = $input.first().json;\n\nconst organicResults = (serpData?.organic_results || []).slice(0, 3).map(r => ({\n  title: r.title || '',\n  snippet: r.snippet || '',\n  link: r.link || ''\n}));\n\nreturn [{\n  json: {\n    ...ctx,\n    serp_results: organicResults,\n    llm_request: {\n      model: 'google/gemini-2.0-flash-001',\n      messages: [\n        {\n          role: 'system',\n          content: 'You are an expert SEO strategist scoring a keyword cluster for B2B ICP fit. Return ONLY raw JSON with: icp_match_score (0-1), icp_match_reasoning, commercial_intent_weight (number per the scale), serp_intent_signals (array of strings), priority_score_inputs object.'\n        },\n        {\n          role: 'user',\n          content: `Score this cluster:\\n\\nHead term: ${ctx.head_term}\\nTheme: ${ctx.theme_label}\\nContent theme: ${ctx.content_theme}\\n\\nSERP results:\\n${JSON.stringify(organicResults, null, 2)}\\n\\nICP persona: ${ctx.client_config?.icp_persona || ''}\\n\\nCommercial intent scale: transactional=5, commercial_investigation=3, navigational_branded=4, local=4, informational=1, navigational_other=0, navigational_competitor=-10\\n\\nReturn: icp_match_score, icp_match_reasoning, commercial_intent_weight, serp_intent_signals, priority_score_inputs (with pillar_match_bonus=1 if pillar assigned else 0, cannibalization_risk_penalty=1 if risk flag else 0).`\n        }\n      ],\n      response_format: { type: 'json_object' },\n      temperature: 0.1,\n      max_tokens: 512\n    }\n  }\n}];"
          },
          "id": "491aa866-2940-4d09-bca5-0d730181cf27",
          "name": "Build_ICP_Request",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            1872,
            512
          ]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "https://openrouter.ai/api/v1/chat/completions",
            "authentication": "genericCredentialType",
            "genericAuthType": "httpHeaderAuth",
            "sendBody": true,
            "bodyParameters": {
              "parameters": [
                {}
              ]
            },
            "options": {}
          },
          "id": "a1902f20-25e7-4acc-affc-8f8e1b97db14",
          "name": "LLM_ICP_Score",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.2,
          "position": [
            2096,
            512
          ]
        },
        {
          "parameters": {
            "jsCode": "// Compute final priority_score and update cluster\nconst ctx = $('Build_ICP_Request').item.json;\nconst llmRaw = $input.first().json;\n\nlet scoring = {};\ntry {\n  scoring = JSON.parse(llmRaw.choices?.[0]?.message?.content || '{}');\n} catch(e) {\n  scoring = { icp_match_score: 0.5, commercial_intent_weight: 1 };\n}\n\nconst inputs = scoring.priority_score_inputs || {};\nconst commercial = scoring.commercial_intent_weight || inputs.commercial_intent_weight || 1;\nconst icpScore = scoring.icp_match_score || 0.5;\nconst totalVolume = ctx.keyword_count || 1; // Proxy since we don't have volume aggregated here\nconst avgKd = 0; // Would need to join keyword_classifications — use 0 as safe default\nconst pillarBonus = (ctx.suggested_service_pillar && ctx.pillar_assignment_confidence > 0.5) ? 1 : 0;\nconst nicheBonus = inputs.niche_focus_bonus || 0;\nconst cannibalPenalty = ctx.cannibalization_risk_page_id ? 1 : 0;\n\nconst priorityScore = (commercial * 5)\n  + (icpScore * 3)\n  + (Math.log(totalVolume + 1) * 1)\n  - (avgKd * 0.5)\n  + (pillarBonus * 1.5)\n  + (nicheBonus * 1)\n  - (cannibalPenalty * 3);\n\nconst inputTokens = llmRaw.usage?.prompt_tokens || 0;\nconst outputTokens = llmRaw.usage?.completion_tokens || 0;\n\nreturn [{\n  json: {\n    client_id: ctx.client_id,\n    pipeline_run_id: ctx.pipeline_run_id,\n    cluster_id: ctx.cluster_id,\n    priority_score: Math.round(priorityScore * 100) / 100,\n    icp_match_score: icpScore,\n    commercial_intent_weight: commercial,\n    llm_tokens: { input: inputTokens, output: outputTokens },\n    serp_cost: 3 * 0.01\n  }\n}];"
          },
          "id": "f13307fc-7368-4bd5-8e73-17a7f1ce37b6",
          "name": "Compute_Priority_Score",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            2304,
